# Copy this file to .env.local and fill in the values.
# .env.local is gitignored — never commit real keys.

# Alchemy RPC URL for Sepolia.
# Get one at https://dashboard.alchemy.com (create a Sepolia app, copy the HTTPS URL).
NEXT_PUBLIC_ALCHEMY_RPC_URL=https://eth-sepolia.g.alchemy.com/v2/YOUR_ALCHEMY_KEY

# Privy app ID for email login + embedded wallets.
# Get one at https://dashboard.privy.io (create an app, copy the App ID).
NEXT_PUBLIC_PRIVY_APP_ID=your-privy-app-id

# Funded Sepolia test key used by the one-off scripts (`register:parent`, `issue:subname`).
# Use a THROWAWAY key, never a real wallet. Fund its address with Sepolia ETH for gas.
# For issue:subname it must OWN the parent name.
DEPLOYER_PRIVATE_KEY=0xyour-throwaway-sepolia-private-key

# OPTIONAL override for the ENSv2 UserRegistry implementation used by the onchain subname path.
# Defaults to the address pinned from ens-cli (0x0F99e7Ea74903AfCB7224d0354fD7428A6f92917) — only
# set this if that address changes.
# NEXT_PUBLIC_USER_REGISTRY_IMPL=0x...
