# Copy this file to .env.local and fill in the values.
# .env.local is gitignored — never commit real keys.

# Alchemy RPC URL for Sepolia.
# Get one at https://dashboard.alchemy.com (create a Sepolia app, copy the HTTPS URL).
NEXT_PUBLIC_ALCHEMY_RPC_URL=https://eth-sepolia.g.alchemy.com/v2/YOUR_ALCHEMY_KEY

# Privy app ID for email login + embedded wallets.
# Get one at https://dashboard.privy.io (create an app, copy the App ID).
NEXT_PUBLIC_PRIVY_APP_ID=your-privy-app-id

# Funded Sepolia test key used ONLY by `npm run register:parent` (the one-off
# demo-parent registration script). Use a THROWAWAY key, never a real wallet.
# Fund its address with Sepolia ETH from a faucet for gas.
DEPLOYER_PRIVATE_KEY=0xyour-throwaway-sepolia-private-key
